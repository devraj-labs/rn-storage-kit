{
  "name": "@devraj-labs/rn-storage-kit",
  "version": "0.3.2",
  "description": "Unified storage API for React Native — MMKV key-value, Keychain secrets, and structured logging behind one interface",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "release": "npm run build && npm publish --access public",
    "prepare": "husky"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-keychain": ">=8.0.0",
    "react-native-mmkv": ">=3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-keychain": "^8.2.0",
    "react-native-mmkv": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "react-native",
    "storage",
    "mmkv",
    "keychain",
    "secure-storage",
    "async-storage",
    "logger",
    "typescript",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/devraj-labs/rn-storage-kit.git"
  },
  "license": "MIT",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/examples/"
    ],
    "moduleNameMapper": {
      "react-native-mmkv": "<rootDir>/src/__mocks__/react-native-mmkv.ts",
      "react-native-keychain": "<rootDir>/src/__mocks__/react-native-keychain.ts"
    },
    "globals": {
      "__DEV__": true
    }
  }
}
